{
  "expo": {
    "name": "Orbyt",
    "slug": "Orbyt",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/playstore-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0B1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.myorbyt.app",
      "infoPlist": {
        "NSContactsUsageDescription": "Orbyt needs access to your contacts to help you import people you want to stay connected with.",
        "NSCalendarsUsageDescription": "Orbyt needs access to your calendar to schedule planned activities.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0B1A"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.myorbyt.app",
      "permissions": [
        "NOTIFICATIONS",
        "READ_CONTACTS",
        "WRITE_CALENDAR",
        "READ_CALENDAR",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Orbyt to access your contacts to import people you want to stay connected with."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Orbyt to access your calendar to schedule planned activities."
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "d7f805d3-38d3-4f4e-9950-e7bac79f0b9d"
      }
    }
  }
}
